generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BetaSignup {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  company   String?
  role      String?
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("beta_signups")
}
